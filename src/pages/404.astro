---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Página no encontrada · Pinturas Moha">
  <div class="wrap" style="padding-top:calc(var(--nh) + 100px);padding-bottom:100px;text-align:center;">
    <p style="font-size:.68rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--acc);margin-bottom:16px;">404</p>
    <h1 style="font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);letter-spacing:-.025em;color:var(--ink);margin-bottom:14px;line-height:1.05;">Página no encontrada</h1>
    <p style="font-size:.97rem;color:var(--ink2);max-width:360px;margin:0 auto 32px;line-height:1.7;">Esta página no existe. Vuelve al inicio o contáctame.</p>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
      <a href="/" class="btn btn-dk">Ir al inicio</a>
      <a href="/contacto" class="btn btn-ol">Contactar</a>
    </div>
  </div>
</Layout>

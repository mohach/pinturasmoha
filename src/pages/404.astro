---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Página no encontrada · Pinturas Moha">
  <div class="container" style="padding-top: calc(var(--nav-h) + 100px); padding-bottom: 100px; text-align: center;">
    <p style="font-size:.7rem; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color:var(--accent); margin-bottom:20px;">404</p>
    <h1 style="font-family:var(--font-serif); font-size:clamp(2rem,4vw,3rem); letter-spacing:-.02em; color:var(--ink); margin-bottom:16px; line-height:1.1;">
      Página no encontrada
    </h1>
    <p style="font-size:1rem; color:var(--ink-2); max-width:400px; margin:0 auto 36px; line-height:1.7;">
      Parece que esta página no existe. Vuelve al inicio o contacta conmigo directamente.
    </p>
    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
      <a href="/" class="btn btn--primary">Ir al inicio</a>
      <a href="/contacto" class="btn btn--outline">Contactar</a>
    </div>
  </div>
</Layout>

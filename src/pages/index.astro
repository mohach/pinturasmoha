---
import Layout from '../layouts/Layout.astro';
const WA = 'https://wa.me/34641891505?text=Hola%20Moha%2C%20me%20gustar%C3%ADa%20pedir%20un%20presupuesto.';
---
<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-g">
      <div>
        <p class="hero-ey">Alaquàs · Valencia</p>
        <h1 class="hero-h1">Pintor profesional.<br>Acabados que duran.</h1>
        <p class="hero-lead">Soy Moha, pintor con años de experiencia en Valencia. Puntualidad, materiales de primera y un cuidado por el detalle que se nota en cada pared.</p>
        <div class="hero-btns">
          <a href={WA} target="_blank" rel="noopener" class="btn btn-dk">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Pedir presupuesto
          </a>
          <a href="/proyectos" class="btn btn-ol">Ver proyectos</a>
        </div>
        <div class="hero-stats">
          <div><div class="sn">+50</div><div class="sl">Proyectos</div></div>
          <div><div class="sn">5.0</div><div class="sl">Google ★</div></div>
          <div><div class="sn">Valencia</div><div class="sl">y alrededores</div></div>
        </div>
      </div>
      <div class="hero-vis">
        <div class="hero-img">
          <img src="https://pinturasmoha.es/wp-content/uploads/2025/12/4fffd528-66c9-453c-8f83-027151cc24ef-683x1024.png"
            alt="Moha, pintor profesional en Valencia" loading="eager"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
          <div class="hero-img-fb" style="display:none">Foto de Moha</div>
        </div>
        <div class="hero-card">
          <div><div class="hero-card-n">Moha</div><div class="hero-card-r">Pintor profesional · Alaquàs</div></div>
          <span class="hero-card-b">Disponible</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="sec sec-alt">
    <div class="wrap">
      <div class="sh-split">
        <div><p class="lbl">Servicios</p><h2 class="h2">Lo que hago</h2></div>
        <a href="/servicios" class="btn btn-ol">Ver todos →</a>
      </div>
      <div class="srv-g">
        <div class="srv"><div class="srv-n">01</div><div class="srv-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div><h3 class="srv-t">Pintura interior</h3><p class="srv-d">Paredes y techos con acabado limpio y uniforme. Materiales de calidad para resultados duraderos.</p></div>
        <div class="srv"><div class="srv-n">02</div><div class="srv-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div><h3 class="srv-t">Pintura exterior</h3><p class="srv-d">Fachadas con productos resistentes al sol, lluvia y humedad mediterránea.</p></div>
        <div class="srv"><div class="srv-n">03</div><div class="srv-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div><h3 class="srv-t">Alisado de gotelé</h3><p class="srv-d">Elimino la textura antigua y dejo las paredes lisas. Un cambio que transforma completamente el espacio.</p></div>
        <div class="srv"><div class="srv-n">04</div><div class="srv-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg></div><h3 class="srv-t">Locales y empresas</h3><p class="srv-d">Oficinas, tiendas y restaurantes. Trabajo en horario flexible para no interrumpir tu actividad.</p></div>
        <div class="srv"><div class="srv-n">05</div><div class="srv-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="19" cy="17" r="2"/><circle cx="7" cy="15" r="3"/><path d="M13.5 9l-6 6M13.5 9l5.5 8"/></svg></div><h3 class="srv-t">Asesoría de color</h3><p class="srv-d">Te ayudo a seleccionar la paleta perfecta para cada estancia según la luz y el uso del espacio.</p></div>
        <div class="srv"><div class="srv-n">06</div><div class="srv-i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg></div><h3 class="srv-t">Limpieza incluida</h3><p class="srv-d">Al finalizar retiro todo el material y entrego el espacio impecable. Sin restos, sin sorpresas.</p></div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="sec">
    <div class="wrap">
      <div class="sh"><p class="lbl">Cómo trabajo</p><h2 class="h2">Sin complicaciones</h2></div>
      <div class="proc">
        <div class="proc-s"><div class="proc-n">1</div><div><div class="proc-t">Contacto</div><p class="proc-d">Escríbeme por WhatsApp o email.</p></div></div>
        <div class="proc-s"><div class="proc-n">2</div><div><div class="proc-t">Visita</div><p class="proc-d">Visita gratuita para evaluar el trabajo.</p></div></div>
        <div class="proc-s"><div class="proc-n">3</div><div><div class="proc-t">Presupuesto</div><p class="proc-d">Detallado y sin compromiso en 24 h.</p></div></div>
        <div class="proc-s"><div class="proc-n">4</div><div><div class="proc-t">Ejecución</div><p class="proc-d">Trabajo limpio, puntual y con garantía.</p></div></div>
        <div class="proc-s"><div class="proc-n">5</div><div><div class="proc-t">Entrega</div><p class="proc-d">Tu espacio impecable y listo.</p></div></div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="sec sec-alt">
    <div class="wrap">
      <div class="about-g">
        <div>
          <p class="lbl">Sobre mí</p>
          <h2 class="h2">Soy Moha</h2>
          <p class="lead">Pintor profesional con años de experiencia renovando viviendas y locales en Valencia. Acabados limpios y duraderos, siempre con materiales de primera calidad.</p>
          <ul class="about-l">
            <li class="about-i">Puntualidad garantizada en cada proyecto</li>
            <li class="about-i">Solo materiales profesionales de primera calidad</li>
            <li class="about-i">Presupuesto sin costes ocultos ni sorpresas</li>
            <li class="about-i">Limpieza completa al finalizar cada trabajo</li>
            <li class="about-i">Servicio en Alaquàs, Valencia y alrededores</li>
          </ul>
        </div>
        <div class="about-img">
          <img src="https://pinturasmoha.es/wp-content/uploads/2025/12/4fffd528-66c9-453c-8f83-027151cc24ef-683x1024.png"
            alt="Moha en un proyecto de pintura" loading="lazy"
            onerror="this.style.display='none';" />
          <div class="about-b">
            <div class="about-bn">5.0 ★</div>
            <div class="about-bt">Google Reviews · Clientes satisfechos</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="sec sec-dark">
    <div class="wrap">
      <div class="sh"><p class="lbl">Opiniones</p><h2 class="h2">Lo que dicen los clientes</h2></div>
      <div class="testi-g">
        <div class="testi"><div class="testi-s">★★★★★</div><p class="testi-t">"Estoy muy contenta por el trabajo realizado. Profesional, cuidadoso y puntual. El resultado fue perfecto."</p><div class="testi-a"><div class="testi-av">AM</div><div><div class="testi-n">Amparo M.</div><div class="testi-src">Google Reviews</div></div></div></div>
        <div class="testi"><div class="testi-s">★★★★★</div><p class="testi-t">"Buen precio, es rápido y lo deja muy bien. Pintó el piso en tiempo récord. Un profesional de verdad."</p><div class="testi-a"><div class="testi-av">AG</div><div><div class="testi-n">Álvaro G.</div><div class="testi-src">Google Reviews</div></div></div></div>
        <div class="testi"><div class="testi-s">★★★★★</div><p class="testi-t">"Excelente trabajo de pintura y reforma. Estamos muy satisfechos con el resultado final."</p><div class="testi-a"><div class="testi-av">LE</div><div><div class="testi-n">League of Eagle</div><div class="testi-src">Google Reviews</div></div></div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="sec">
    <div class="wrap">
      <div class="cta">
        <div><h2 class="cta-t">¿Listo para renovar tu espacio?</h2><p class="cta-s">Presupuesto gratuito · Respuesta en menos de 24 horas</p></div>
        <a href={WA} target="_blank" rel="noopener" class="btn btn-ac">Contactar por WhatsApp →</a>
      </div>
    </div>
  </section>
</Layout>

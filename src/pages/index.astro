---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pinturas Moha · Pintor Profesional en Alaquàs, Valencia" currentPage="/">

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero__inner">

      <div class="hero__text">
        <p class="hero__eyebrow">Alaquàs · Valencia</p>
        <h1 class="hero__h1">Pintura profesional.<br>Acabados que duran.</h1>
        <p class="hero__lead">
          Soy Moha, pintor con años de experiencia en Valencia. Trabajo con puntualidad,
          materiales de primera y un cuidado por el detalle que se nota en cada pared.
        </p>
        <div class="hero__actions">
          <a
            href="https://wa.me/34641891505?text=Hola%20Moha%2C%20me%20gustar%C3%ADa%20pedir%20un%20presupuesto."
            target="_blank"
            rel="noopener"
            class="btn btn--primary"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Pedir presupuesto
          </a>
          <a href="/proyectos" class="btn btn--outline">Ver proyectos</a>
        </div>

        <div class="hero__stats">
          <div>
            <div class="stat__number">+50</div>
            <div class="stat__label">Proyectos</div>
          </div>
          <div>
            <div class="stat__number">5.0</div>
            <div class="stat__label">Google ★</div>
          </div>
          <div>
            <div class="stat__number">Valencia</div>
            <div class="stat__label">y alrededores</div>
          </div>
        </div>
      </div>

      <!-- HERO VISUAL -->
      <div class="hero__visual">
        <div class="hero__photo-wrap">
          <img
            src="https://pinturasmoha.es/wp-content/uploads/2025/12/4fffd528-66c9-453c-8f83-027151cc24ef-683x1024.png"
            alt="Moha, pintor profesional en Valencia"
            width="683"
            height="1024"
            loading="eager"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="hero__photo-placeholder" style="display:none">
            Foto de Moha
          </div>
        </div>
        <div class="hero__photo-label">
          <div>
            <div class="hero__photo-name">Moha</div>
            <div class="hero__photo-role">Pintor profesional · Alaquàs</div>
          </div>
          <span class="hero__photo-badge">Disponible</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ── SERVICIOS ── -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header section__header--split">
        <div>
          <p class="section__label">Servicios</p>
          <h2 class="section__h2">Lo que hago</h2>
        </div>
        <a href="/servicios" class="btn btn--outline" style="flex-shrink:0">Ver todos los servicios →</a>
      </div>

      <div class="services__grid">

        <div class="service__card">
          <div class="service__num">01</div>
          <div class="service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <h3 class="service__title">Pintura interior</h3>
          <p class="service__desc">Paredes y techos con acabado limpio y uniforme. Materiales de calidad para resultados duraderos.</p>
        </div>

        <div class="service__card">
          <div class="service__num">02</div>
          <div class="service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <h3 class="service__title">Pintura exterior</h3>
          <p class="service__desc">Fachadas con productos resistentes al sol, lluvia y humedad mediterránea. Protección duradera.</p>
        </div>

        <div class="service__card">
          <div class="service__num">03</div>
          <div class="service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="service__title">Alisado de gotelé</h3>
          <p class="service__desc">Elimino la textura antigua y dejo las paredes lisas. Un cambio que transforma completamente el espacio.</p>
        </div>

        <div class="service__card">
          <div class="service__num">04</div>
          <div class="service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 12h8M12 8v8"/>
            </svg>
          </div>
          <h3 class="service__title">Locales y empresas</h3>
          <p class="service__desc">Oficinas, tiendas y restaurantes. Trabajo en horario flexible para no interrumpir tu actividad.</p>
        </div>

        <div class="service__card">
          <div class="service__num">05</div>
          <div class="service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="13.5" cy="6.5" r="2.5"/>
              <circle cx="19" cy="17" r="2"/>
              <circle cx="7" cy="15" r="3"/>
              <path d="M13.5 9l-6 6M13.5 9l5.5 8"/>
            </svg>
          </div>
          <h3 class="service__title">Asesoría de color</h3>
          <p class="service__desc">¿No sabes qué color elegir? Te ayudo a seleccionar la paleta perfecta para cada estancia.</p>
        </div>

        <div class="service__card">
          <div class="service__num">06</div>
          <div class="service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h3 class="service__title">Limpieza incluida</h3>
          <p class="service__desc">Al finalizar retiro todo el material y dejo el espacio impecable. Sin sorpresas, sin restos.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PROCESO ── -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <p class="section__label">Cómo trabajo</p>
        <h2 class="section__h2">Sin complicaciones</h2>
      </div>
      <div class="proceso__steps">
        <div class="proceso__step">
          <div class="proceso__num">1</div>
          <div>
            <div class="proceso__title">Contacto</div>
            <p class="proceso__desc">Escríbeme por WhatsApp o email.</p>
          </div>
        </div>
        <div class="proceso__step">
          <div class="proceso__num">2</div>
          <div>
            <div class="proceso__title">Visita</div>
            <p class="proceso__desc">Visita gratuita para evaluar el trabajo.</p>
          </div>
        </div>
        <div class="proceso__step">
          <div class="proceso__num">3</div>
          <div>
            <div class="proceso__title">Presupuesto</div>
            <p class="proceso__desc">Presupuesto detallado en 24 horas.</p>
          </div>
        </div>
        <div class="proceso__step">
          <div class="proceso__num">4</div>
          <div>
            <div class="proceso__title">Ejecución</div>
            <p class="proceso__desc">Trabajo limpio, puntual y con garantía.</p>
          </div>
        </div>
        <div class="proceso__step">
          <div class="proceso__num">5</div>
          <div>
            <div class="proceso__title">Entrega</div>
            <p class="proceso__desc">Tu espacio impecable y listo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ABOUT ── -->
  <section class="section section--alt">
    <div class="container">
      <div class="about__inner">
        <div>
          <p class="section__label">Sobre mí</p>
          <h2 class="section__h2">Soy Moha</h2>
          <p class="section__lead">
            Pintor profesional con años de experiencia renovando viviendas y locales en Valencia.
            Me especializo en acabados limpios y duraderos, trabajando siempre con materiales de primera calidad.
          </p>
          <ul class="about__list">
            <li class="about__item">Puntualidad garantizada en cada proyecto</li>
            <li class="about__item">Materiales profesionales de primera calidad</li>
            <li class="about__item">Presupuesto sin costes ocultos ni sorpresas</li>
            <li class="about__item">Limpieza completa al finalizar cada trabajo</li>
            <li class="about__item">Servicio en Alaquàs, Valencia y alrededores</li>
          </ul>
        </div>
        <div class="about__img-wrap">
          <img
            src="https://pinturasmoha.es/wp-content/uploads/2025/12/4fffd528-66c9-453c-8f83-027151cc24ef-683x1024.png"
            alt="Moha trabajando en un proyecto de pintura"
            loading="lazy"
            onerror="this.parentElement.querySelector('.about__img-placeholder').style.display='flex'; this.style.display='none';"
          />
          <div class="about__img-placeholder" style="display:none; width:100%; height:100%; align-items:center; justify-content:center; background:var(--bg-2); color:var(--ink-4); font-size:.78rem; letter-spacing:.06em; text-transform:uppercase;">
            Foto de trabajo
          </div>
          <div class="about__img-badge">
            <div class="about__img-badge-num">5.0 ★</div>
            <div class="about__img-badge-text">Google Reviews · Clientes satisfechos</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="section section--dark">
    <div class="container">
      <div class="section__header">
        <p class="section__label" style="color:var(--accent)">Opiniones</p>
        <h2 class="section__h2">Lo que dicen los clientes</h2>
      </div>
      <div class="testi__grid">
        <div class="testi__card">
          <div class="testi__stars">★★★★★</div>
          <p class="testi__text">"Estoy muy contenta por el trabajo realizado. Profesional, cuidadoso y puntual. El resultado fue perfecto."</p>
          <div class="testi__author">
            <div class="testi__avatar">AM</div>
            <div>
              <div class="testi__name">Amparo M.</div>
              <div class="testi__source">Google Reviews</div>
            </div>
          </div>
        </div>
        <div class="testi__card">
          <div class="testi__stars">★★★★★</div>
          <p class="testi__text">"Buen precio, es rápido y lo deja muy bien. Pintó el piso en tiempo récord. Un profesional de verdad."</p>
          <div class="testi__author">
            <div class="testi__avatar">AG</div>
            <div>
              <div class="testi__name">Álvaro G.</div>
              <div class="testi__source">Google Reviews</div>
            </div>
          </div>
        </div>
        <div class="testi__card">
          <div class="testi__stars">★★★★★</div>
          <p class="testi__text">"Excelente trabajo de pintura y reforma. Estamos muy satisfechos con el resultado final."</p>
          <div class="testi__author">
            <div class="testi__avatar">LE</div>
            <div>
              <div class="testi__name">League of Eagle</div>
              <div class="testi__source">Google Reviews</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <div>
          <h2 class="cta-banner__title">¿Listo para renovar tu espacio?</h2>
          <p class="cta-banner__sub">Presupuesto gratuito · Respuesta en menos de 24 horas</p>
        </div>
        <a
          href="https://wa.me/34641891505?text=Hola%20Moha%2C%20me%20gustar%C3%ADa%20pedir%20un%20presupuesto."
          target="_blank"
          rel="noopener"
          class="btn btn--accent"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="width:18px;height:18px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </section>

</Layout>

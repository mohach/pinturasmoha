---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    slug: 'piso-alaquas',
    title: 'Piso completo en Alaquàs',
    location: 'Alaquàs, Valencia',
    desc: 'Renovación integral de un piso de 90 m². Alisado previo del gotelé en todas las estancias, aparejado y pintura final en blanco mate de alta cobertura.',
    tags: ['Interior', 'Alisado'],
    imgSrc: 'https://pinturasmoha.es/wp-content/uploads/2025/12/IMG-20251207-WA0005.jpg',
    year: '2024',
  },
  {
    slug: 'piso-torrent',
    title: 'Fachada y piso en Torrent',
    location: 'Torrent, Valencia',
    desc: 'Pintura de fachada exterior con pintura plástica antihumedad y renovación completa del interior. Trabajo ejecutado en dos semanas.',
    tags: ['Exterior', 'Interior'],
    imgSrc: 'https://pinturasmoha.es/wp-content/uploads/2025/12/IMG_20201010_154758-scaled.jpg',
    year: '2024',
  },
  {
    slug: 'dormitorios-campanar',
    title: 'Dormitorios con color en Campanar',
    location: 'Campanar, Valencia',
    desc: 'Tres dormitorios con paletas personalizadas: verde salvia, azul serenity y gris perla. Asesoría de color incluida para crear ambientes únicos.',
    tags: ['Interior', 'Asesoría'],
    imgSrc: '',
    year: '2025',
  },
  {
    slug: 'cocina-manises',
    title: 'Cocina y baños en Manises',
    location: 'Manises, Valencia',
    desc: 'Pintura especial antivapor para cocina y baños. Pintura sobre azulejos para renovar sin obra. Resultado moderno y duradero.',
    tags: ['Interior', 'Especial'],
    imgSrc: '',
    year: '2025',
  },
  {
    slug: 'oficina-alaquas',
    title: 'Oficina comercial en Alaquàs',
    location: 'Alaquàs, Valencia',
    desc: 'Pintura corporativa en blanco roto con pared de acento en azul marino. Trabajo en fin de semana para no interrumpir la actividad laboral.',
    tags: ['Locales', 'Interior'],
    imgSrc: '',
    year: '2025',
  },
  {
    slug: 'chalet-xirivella',
    title: 'Alisado de chalet en Xirivella',
    location: 'Xirivella, Valencia',
    desc: 'Eliminación total de gotelé en 140 m². Alisado a espátula, aparejado y pintura final. Un trabajo que transformó por completo el aspecto del inmueble.',
    tags: ['Alisado', 'Interior'],
    imgSrc: '',
    year: '2025',
  },
];
---
<Layout
  title="Proyectos · Pinturas Moha"
  description="Proyectos de pintura realizados en Alaquàs, Valencia y alrededores. Pintura interior, exterior y alisado de gotelé."
  currentPage="/proyectos"
>

  <div class="container">
    <header class="page-header">
      <p class="page-header__label">Portafolio</p>
      <h1 class="page-header__h1">Proyectos realizados</h1>
      <p class="page-header__lead">
        Cada proyecto es un reto diferente. Una selección de trabajos recientes
        en Alaquàs, Valencia y municipios del área metropolitana.
      </p>
    </header>
  </div>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="projects__grid">
        {projects.map(p => (
          <article class="project__card">
            <div class="project__img">
              {p.imgSrc
                ? (
                  <img
                    src={p.imgSrc}
                    alt={p.title}
                    loading="lazy"
                    onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
                  />
                )
                : null
              }
              <div
                class="project__img-placeholder"
                style={p.imgSrc ? 'display:none' : 'display:flex'}
              >
                {p.location}
              </div>
              <span class="project__tag">{p.year}</span>
            </div>
            <div class="project__body">
              <p class="project__location">{p.location}</p>
              <h2 class="project__title">{p.title}</h2>
              <p class="project__desc">{p.desc}</p>
              <div class="project__footer">
                <div class="project__tags">
                  {p.tags.map(t => <span class="project__chip">{t}</span>)}
                </div>
                <div class="project__arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA -->
      <div class="cta-banner" style="margin-top:64px">
        <div>
          <h2 class="cta-banner__title">¿Quieres un proyecto así?</h2>
          <p class="cta-banner__sub">Cuéntame qué necesitas y te envío presupuesto en 24 horas.</p>
        </div>
        <a
          href="https://wa.me/34641891505?text=Hola%20Moha%2C%20he%20visto%20tus%20proyectos%20y%20me%20gustar%C3%ADa%20pedir%20presupuesto."
          target="_blank"
          rel="noopener"
          class="btn btn--accent"
        >
          Pedir presupuesto →
        </a>
      </div>

    </div>
  </section>

</Layout>

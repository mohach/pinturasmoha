---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    num: '01',
    title: 'Pintura interior',
    desc: 'Transformo paredes y techos con un acabado limpio y uniforme. Preparo correctamente las superficies, aplico imprimación donde es necesario y trabajo con pinturas de primera calidad. El resultado son paredes perfectas que duran años sin perder el color ni la textura.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
  },
  {
    num: '02',
    title: 'Pintura exterior',
    desc: 'Pinto fachadas y superficies exteriores con productos formulados para el clima mediterráneo: resistentes al sol intenso, la lluvia y la humedad. Un resultado duradero que mejora la imagen de tu vivienda y la protege contra la erosión durante años.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    num: '03',
    title: 'Alisado de gotelé',
    desc: 'Elimino el gotelé y cualquier textura antigua de tus paredes para dejarlas totalmente lisas. Una solución moderna que cambia por completo el aspecto de cualquier habitación. Trabajo limpio, sin polvo innecesario, con el método húmedo más eficiente.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
  },
  {
    num: '04',
    title: 'Imprimación y sellado',
    desc: 'Antes de pintar aplico imprimaciones y selladores que garantizan una perfecta adhesión y la máxima durabilidad. Fundamental en superficies nuevas, muy porosas o cuando se cambia de colores oscuros a claros.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>`,
  },
  {
    num: '05',
    title: 'Locales y empresas',
    desc: 'Renuevo oficinas, tiendas, restaurantes y cualquier local comercial. Trabajo en horario flexible —incluidos fines de semana— para minimizar el impacto en tu negocio. Presupuestos especiales para comunidades de vecinos y grandes superficies.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>`,
  },
  {
    num: '06',
    title: 'Efectos decorativos',
    desc: 'Estuco veneciano, microcemento, pintura con efecto tiza o metálico. Si buscas algo diferente y exclusivo para tu hogar o negocio, te propongo soluciones creativas que transforman el espacio en algo único.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="19" cy="17" r="2"/><circle cx="7" cy="15" r="3"/><path d="M13.5 9l-6 6M13.5 9l5.5 8"/></svg>`,
  },
  {
    num: '07',
    title: 'Asesoría de color',
    desc: '¿No sabes qué color elegir? Mi experiencia y ojo para el diseño están a tu disposición. Te asesoro sobre tendencias, tonos y combinaciones perfectas para cada tipo de espacio, iluminación y estilo de vida.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    num: '08',
    title: 'Limpieza post-obra',
    desc: 'Al finalizar cada proyecto realizo una limpieza exhaustiva: retiro protecciones, limpio cualquier resto accidental y te entrego el espacio listo para usar desde el primer momento. Sin extra, incluido en el precio.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>`,
  },
];
---
<Layout
  title="Servicios · Pinturas Moha"
  description="Pintura interior y exterior, alisado de gotelé, locales y empresas. Pintor profesional en Alaquàs, Valencia."
  currentPage="/servicios"
>

  <div class="container">
    <header class="page-header">
      <p class="page-header__label">Servicios profesionales</p>
      <h1 class="page-header__h1">Todo lo que necesita<br>tu espacio</h1>
      <p class="page-header__lead">
        Pintura interior y exterior, alisado de gotelé, efectos decorativos y más.
        Trabajo con materiales profesionales para resultados duraderos.
      </p>
    </header>
  </div>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="services__grid">
        {services.map(s => (
          <div class="service__card">
            <div class="service__num">{s.num}</div>
            <div class="service__icon" set:html={s.icon} />
            <h2 class="service__title">{s.title}</h2>
            <p class="service__desc">{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="cta-banner" style="margin-top:64px">
        <div>
          <h2 class="cta-banner__title">¿Tienes un proyecto en mente?</h2>
          <p class="cta-banner__sub">Presupuesto gratuito · Sin compromiso · Respuesta en 24 horas</p>
        </div>
        <a
          href="https://wa.me/34641891505?text=Hola%20Moha%2C%20me%20gustar%C3%ADa%20pedir%20un%20presupuesto%20de%20pintura."
          target="_blank"
          rel="noopener"
          class="btn btn--accent"
        >
          Solicitar presupuesto →
        </a>
      </div>
    </div>
  </section>

</Layout>

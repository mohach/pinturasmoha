---
import Layout from '../../layouts/Layout.astro';
import { posts, postBodies } from '../../data/posts.js';

export function getStaticPaths() {
  return posts.map(p => ({
    params: { slug: p.slug },
    props:  { post: p },
  }));
}

const { post } = Astro.props;
const body = postBodies[post.slug] || '';
const related = posts.filter(p => p.slug !== post.slug).slice(0, 2);
const WA = `https://wa.me/34641891505?text=Hola%20Moha%2C%20he%20le%C3%ADdo%20tu%20art%C3%ADculo%20y%20me%20gustar%C3%ADa%20pedir%20presupuesto.`;
---
<Layout
  title={`${post.title} · Blog · Pinturas Moha`}
  description={post.excerpt}
  image={post.img}
  type="article"
>
  <div class="art">
    <div class="wrap">
      <a href="/blog" class="art-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver al blog
      </a>

      <header class="art-hd">
        <span class="art-cat">{post.cat}</span>
        <h1 class="art-h1">{post.title}</h1>
        <div class="art-meta">
          <span class="art-mi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {post.date}
          </span>
          <span class="art-mi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {post.readTime} lectura
          </span>
          <span class="art-mi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Moha · Pintor profesional
          </span>
        </div>
      </header>

      <img src={post.img} alt={post.imgAlt} class="art-cover" loading="eager"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
      <div class="art-cover-ph" style="display:none">Pinturas Moha · {post.cat}</div>

      <div class="art-body">
        <Fragment set:html={body} />
      </div>

      <div class="cta" style="margin-top:64px">
        <div><h2 class="cta-t">¿Necesitas un presupuesto?</h2><p class="cta-s">Escríbeme y te respondo en menos de 24 horas.</p></div>
        <a href={WA} target="_blank" rel="noopener" class="btn btn-ac">Contactar por WhatsApp →</a>
      </div>

      {related.length > 0 && (
        <div style="margin-top:72px;padding-top:52px;border-top:1px solid var(--border)">
          <p class="lbl">Más artículos</p>
          <h2 class="h2" style="margin-bottom:28px">Seguir leyendo</h2>
          <div class="blog-g">
            {related.map(r => (
              <a href={`/blog/${r.slug}`} class="blog">
                <div class="blog-img">
                  <img src={r.img} alt={r.imgAlt} loading="lazy"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                  <div class="blog-img-ph" style="display:none">{r.cat}</div>
                </div>
                <div class="blog-body">
                  <span class="blog-cat">{r.cat}</span>
                  <h3 class="blog-title">{r.title}</h3>
                  <p class="blog-exc">{r.excerpt}</p>
                  <div class="blog-meta">
                    <span class="blog-date">{r.date} · {r.readTime} lectura</span>
                    <span class="blog-more">Leer <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>

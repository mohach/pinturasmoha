---
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/posts.js';
---
<Layout title="Blog · Pinturas Moha" description="Consejos, técnicas y guías de pintura escritas por un pintor profesional en Valencia.">
  <div class="wrap">
    <header class="ph">
      <p class="lbl">Consejos y artículos</p>
      <h1 class="ph-h1">Blog de pintura</h1>
      <p class="ph-lead">Trucos, técnicas y guías escritas desde la experiencia real. Todo lo que necesitas saber antes de empezar un proyecto.</p>
    </header>
  </div>
  <section class="sec" style="padding-top:0">
    <div class="wrap">
      <div class="blog-g">
        {posts.map(p => (
          <a href={`/blog/${p.slug}`} class="blog">
            <div class="blog-img">
              <img
                src={p.img}
                alt={p.imgAlt}
                loading="lazy"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
              />
              <div class="blog-img-ph" style="display:none">{p.cat}</div>
            </div>
            <div class="blog-body">
              <span class="blog-cat">{p.cat}</span>
              <h2 class="blog-title">{p.title}</h2>
              <p class="blog-exc">{p.excerpt}</p>
              <div class="blog-meta">
                <span class="blog-date">{p.date} · {p.readTime} lectura</span>
                <span class="blog-more">Leer <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

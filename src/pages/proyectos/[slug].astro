---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map(p => ({
    params: { slug: p.slug },
    props:  { project: p },
  }));
}

const { project: p } = Astro.props;
const related = projects.filter(x => x.slug !== p.slug);
const WA = `https://wa.me/34641891505?text=Hola%20Moha%2C%20he%20visto%20el%20proyecto%20%22${encodeURIComponent(p.title)}%22%20y%20me%20gustar%C3%ADa%20pedir%20presupuesto.`;
---
<Layout
  title={`${p.title} · Proyectos · Pinturas Moha`}
  description={`${p.excerpt} Pintor profesional en ${p.location}.`}
>
<div class="pd">
  <div class="wrap">

    <a href="/proyectos" class="back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Todos los proyectos
    </a>

    <div class="pd-g">

      <!-- LEFT: all photos + description -->
      <div>

        <!-- Hero image -->
        <div class="pd-hero">
          <img src={p.imgMain} alt={p.title} loading="eager"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
          <div class="pd-hero-ph" style="display:none">{p.location}</div>
        </div>

        <!-- BEFORE section -->
        {p.before && p.before.length > 0 && (
          <div class="pd-gallery-section">
            <div class="pd-gallery-label">
              <span class="pd-gallery-pill pd-gallery-pill--before">Antes</span>
            </div>
            <div class={`pd-gallery pd-gallery--${p.before.length === 1 ? 'single' : 'multi'}`}>
              {p.before.map(img => (
                <div class="pd-gal-item">
                  <img src={img.src} alt={img.alt} loading="lazy"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                  <div class="pd-gal-ph" style="display:none">Foto</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- AFTER section -->
        {p.after && p.after.length > 0 && (
          <div class="pd-gallery-section">
            <div class="pd-gallery-label">
              <span class="pd-gallery-pill pd-gallery-pill--after">Después</span>
            </div>
            <div class={`pd-gallery pd-gallery--${p.after.length === 1 ? 'single' : 'multi'}`}>
              {p.after.map(img => (
                <div class="pd-gal-item">
                  <img src={img.src} alt={img.alt} loading="lazy"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                  <div class="pd-gal-ph" style="display:none">Foto</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Description -->
        <div class="pd-description">
          {p.description.split('\n\n').map(para => (
            <p>{para}</p>
          ))}
        </div>

      </div>

      <!-- RIGHT: sticky sidebar -->
      <aside class="pd-sidebar">
        <p class="pd-cat">Proyecto</p>
        <h1 class="pd-title">{p.title}</h1>
        <p class="pd-desc">{p.excerpt}</p>

        <div class="pd-meta">
          <div class="pd-row"><span class="pd-rl">Ubicación</span><span class="pd-rv">{p.location}</span></div>
          <div class="pd-row"><span class="pd-rl">Año</span><span class="pd-rv">{p.year}</span></div>
          <div class="pd-row"><span class="pd-rl">Duración</span><span class="pd-rv">{p.duration}</span></div>
          <div class="pd-row"><span class="pd-rl">Zona</span><span class="pd-rv">{p.surface}</span></div>
          <div class="pd-row">
            <span class="pd-rl">Servicios</span>
            <div class="pd-tags-row">
              {p.services.map(s => <span class="proj-tag">{s}</span>)}
            </div>
          </div>
        </div>

        <a href={WA} target="_blank" rel="noopener" class="btn btn-dk" style="width:100%;justify-content:center;margin-bottom:10px;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Pedir presupuesto similar
        </a>
        <a href="/proyectos" class="btn btn-ol" style="width:100%;justify-content:center;">
          Ver todos los proyectos
        </a>
      </aside>

    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div style="margin-top:80px;padding-top:52px;border-top:1px solid var(--border)">
        <p class="lbl">Otros proyectos</p>
        <h2 class="h2" style="margin-bottom:32px">Más trabajos realizados</h2>
        <div class="proj-g">
          {related.map(r => (
            <a href={`/proyectos/${r.slug}`} class="proj">
              <div class="proj-img">
                <img src={r.imgMain} alt={r.title} loading="lazy"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                <div class="proj-img-ph" style="display:none">{r.location}</div>
                <span class="proj-yr">{r.year}</span>
              </div>
              <div class="proj-body">
                <p class="proj-loc">{r.location}</p>
                <h3 class="proj-title">{r.title}</h3>
                <p class="proj-exc">{r.excerpt}</p>
                <div class="proj-foot">
                  <div class="proj-tags">{r.services.map(s => <span class="proj-tag">{s}</span>)}</div>
                  <span class="proj-arr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg></span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</div>
</Layout>

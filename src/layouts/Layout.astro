---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
}

const {
  title = 'Pinturas Moha · Pintor Profesional en Alaquàs, Valencia',
  description = 'Pintor profesional en Alaquàs y Valencia. Pintura interior, exterior, alisado de gotelé. Presupuesto gratuito en 24h.',
  currentPage = '',
} = Astro.props;

const navLinks = [
  { href: '/',           label: 'Inicio'     },
  { href: '/servicios',  label: 'Servicios'  },
  { href: '/proyectos',  label: 'Proyectos'  },
  { href: '/blog',       label: 'Blog'       },
  { href: '/contacto',   label: 'Contacto'   },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon – use real logo if available -->
  <link rel="icon" href="https://pinturasmoha.es/wp-content/uploads/2025/12/painter1.png" type="image/png" />
</head>
<body>

<!-- ── NAV ── -->
<nav class="nav" id="mainNav" role="navigation" aria-label="Navegación principal">
  <div class="nav__inner">

    <!-- Logo: use real image from site -->
    <a href="/" class="nav__logo" aria-label="Pinturas Moha – Inicio">
      <img
        src="https://pinturasmoha.es/wp-content/uploads/2025/12/painter1.png"
        alt="Pinturas Moha logo"
        height="36"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <!-- Fallback text logo if image fails -->
      <span style="display:none; align-items:center; gap:6px; font-weight:700; font-size:1rem; color:var(--ink); letter-spacing:-.01em;">
        Pinturas<span style="color:var(--accent)">Moha</span>
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="nav__links" role="list">
      {navLinks.map(link => {
        const linkPath = link.href.replace(/\/$/, '') || '/';
        const isActive = pathname === linkPath || (linkPath !== '/' && pathname.startsWith(linkPath));
        return (
          <li>
            <a href={link.href} class={`nav__link${isActive ? ' active' : ''}`}>
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <a
      href="https://wa.me/34641891505?text=Hola%20Moha%2C%20me%20gustar%C3%ADa%20pedir%20un%20presupuesto."
      target="_blank"
      rel="noopener noreferrer"
      class="nav__cta"
      aria-label="Contactar por WhatsApp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>

    <!-- Hamburger -->
    <button class="nav__burger" id="burger" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div class="nav__mobile" id="mobileMenu" role="dialog" aria-label="Menú móvil">
  {navLinks.map(link => {
    const linkPath = link.href.replace(/\/$/, '') || '/';
    const isActive = pathname === linkPath || (linkPath !== '/' && pathname.startsWith(linkPath));
    return (
      <a href={link.href} class={`nav__mobile-link${isActive ? ' active' : ''}`}>
        {link.label}
      </a>
    );
  })}
</div>

<!-- ── PAGE CONTENT ── -->
<main id="main-content">
  <slot />
</main>

<!-- ── FOOTER ── -->
<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__inner">

      <div>
        <div class="footer__logo">
          <img
            src="https://pinturasmoha.es/wp-content/uploads/2025/12/painter1.png"
            alt="Pinturas Moha"
            height="32"
            onerror="this.style.display='none'"
          />
        </div>
        <p class="footer__tagline">Pintor profesional en Alaquàs, Valencia. Calidad que se nota en cada acabado.</p>
        <div class="footer__contact-line">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.08 6.08l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0121.73 15l.19 1.92z"/></svg>
          +34 641 89 15 05
        </div>
        <div class="footer__contact-line">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          info@pinturasmoha.es
        </div>
        <div class="footer__contact-line">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Alaquàs, Valencia
        </div>
      </div>

      <div>
        <p class="footer__col-title">Páginas</p>
        <a href="/" class="footer__link">Inicio</a>
        <a href="/servicios" class="footer__link">Servicios</a>
        <a href="/proyectos" class="footer__link">Proyectos</a>
        <a href="/blog" class="footer__link">Blog</a>
        <a href="/contacto" class="footer__link">Contacto</a>
      </div>

      <div>
        <p class="footer__col-title">Servicios</p>
        <span class="footer__link">Pintura interior</span>
        <span class="footer__link">Pintura exterior</span>
        <span class="footer__link">Alisado de gotelé</span>
        <span class="footer__link">Locales y empresas</span>
        <span class="footer__link">Asesoría de color</span>
      </div>

    </div>

    <div class="footer__bottom">
      <span class="footer__copy">© 2025 Pinturas Moha · Alaquàs, Valencia</span>
      <div class="footer__socials">
        <a href="https://www.tiktok.com/@pinturasmoha" target="_blank" rel="noopener" class="footer__social" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/></svg>
        </a>
        <a href="https://www.instagram.com/pinturasmoha/" target="_blank" rel="noopener" class="footer__social" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="mailto:info@pinturasmoha.es" class="footer__social" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<!-- WhatsApp float -->
<a
  href="https://wa.me/34641891505?text=Hola%20Moha%2C%20me%20gustar%C3%ADa%20solicitar%20un%20presupuesto."
  target="_blank"
  rel="noopener noreferrer"
  class="wa-float"
  aria-label="Contactar por WhatsApp"
>
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<script>
  // Nav scroll shadow
  const nav = document.getElementById('mainNav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Mobile menu
  const burger = document.getElementById('burger');
  const menu   = document.getElementById('mobileMenu');
  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
  });

  // Close menu on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

</body>
</html>
